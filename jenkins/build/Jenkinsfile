pipeline {
    agent { label 'builder-slave-ubuntu' }
    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }
    stages {
        stage('Validate CDK') {
            steps {
                dir('cdk') {
                    sh '''
                    npm ci
                    npm test
                    npm run synth
                    '''
                }
            }
        }
    }
    post { always { cleanWs() } }
}
