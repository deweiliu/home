{
  "name": "laundry-site-cdk",
  "version": "1.0.0",
  "private": true,
  "description": "CDK stack for deploying the laundry site to S3 and CloudFront.",
  "bin": {
    "cdk": "bin/cdk.js"
  },
  "scripts": {
    "synth": "cdk synth",
